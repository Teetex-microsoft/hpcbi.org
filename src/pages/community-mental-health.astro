    <a href="/images/gallery/community-1/6.jpg">
      <img
        src="/images/gallery/community-1/6.jpg"
        alt="Community Outreach 6"
        class="w-full max-w-sm rounded-3xl shadow-xl hover:scale-105 transition duration-300"
      />
    </a>

  </div>

</div>

  </div>

</section>

<!-- WHY PARTNER WITH HPCBI -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-600 font-semibold"
      >

        WHY WORK WITH US

      </p>

      <h2
        class="mt-6 text-5xl font-bold text-slate-900"
      >

        Why Communities Choose HPCBI

      </h2>

    </div>

    <div
      class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20"
    >

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl"> </div>

        <h3 class="mt-6 text-2xl font-bold">

          Evidence-Based

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Our programmes are informed by research,
