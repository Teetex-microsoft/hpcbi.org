---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Government Capacity Building | HealthPsyche and CareBridge Initiatives">

<!-- ====================================================== -->
<!-- HERO -->
<!-- ====================================================== -->

<section
  class="relative h-[75vh] bg-cover bg-center"
  style="background-image:url('/images/gallery/treasury/1.jpg');"
>
  <div class="absolute inset-0 bg-black/65"></div>

  <div class="relative z-10 flex h-full items-center justify-center px-8">

    <div class="max-w-5xl text-center text-white">

      <p class="uppercase tracking-[0.35em] text-green-300 font-semibold">

        GOVERNMENT CAPACITY BUILDING

      </p>

      <h1 class="mt-8 text-5xl md:text-7xl font-extrabold leading-tight">

        Building Stronger

        <span class="text-green-300">

          Public Institutions

        </span>

      </h1>

      <p class="mt-10 text-xl leading-10">

        Equipping civil servants with practical knowledge in workplace
        effectiveness, mental wellbeing, leadership, emotional intelligence
        and organisational excellence.

      </p>

    </div>

  </div>

</section>

<!-- ====================================================== -->
<!-- INTRODUCTION -->
<!-- ====================================================== -->

<section class="py-24 bg-white">

  <div class="max-w-6xl mx-auto px-8 text-center">

    <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

      OUR PROGRAMME

    </p>

    <h2 class="mt-6 text-5xl font-bold text-slate-900">

      Strengthening Public Service Through Capacity Building

    </h2>

    <p class="mt-10 text-lg leading-9 text-gray-700">

      HealthPsyche and CareBridge Initiatives (HPCBI) partners with
      government ministries, departments and agencies to strengthen the
      capacity of public servants through practical, engaging and evidence-
      based professional development programmes.

    </p>

    <p class="mt-8 text-lg leading-9 text-gray-700">

      Our training equips participants with the knowledge, skills and
      attitudes required to improve workplace wellbeing, increase
      productivity, strengthen teamwork and enhance the quality of public
      service delivery.

    </p>

  </div>

</section>

<!-- ====================================================== -->
<!-- TRAINING AREAS -->
<!-- ====================================================== -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        OUR EXPERTISE

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Key Training Areas

      </h2>

      <p class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto">

        Every workshop is tailored to the realities of today's workplace,
        helping public institutions build resilient, productive and
        people-centred organisations.

      </p>

    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20">

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🧠</div>

        <h3 class="mt-6 text-2xl font-bold">

          Workplace Mental Wellbeing

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Helping employees maintain good mental health while improving
          workplace performance.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">❤️</div>

        <h3 class="mt-6 text-2xl font-bold">

          Emotional Intelligence

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Building self-awareness, empathy and stronger interpersonal
          relationships.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🤝</div>

        <h3 class="mt-6 text-2xl font-bold">

          Conflict Management

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Practical approaches for resolving workplace disagreements and
          strengthening collaboration.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🔄</div>

        <h3 class="mt-6 text-2xl font-bold">

          Change Management

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Preparing organisations and staff to successfully adapt to change
          and innovation.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">💼</div>

        <h3 class="mt-6 text-2xl font-bold">

          Leadership Development

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Developing confident leaders capable of inspiring excellence and
          accountability.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">💬</div>

        <h3 class="mt-6 text-2xl font-bold">

          Communication Skills

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Enhancing communication for stronger teamwork and better public
          engagement.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🌱</div>

        <h3 class="mt-6 text-2xl font-bold">

          Stress Management

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Equipping participants with practical strategies for maintaining
          resilience under pressure.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🚀</div>

        <h3 class="mt-6 text-2xl font-bold">

          Workplace Effectiveness

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Building productive teams that deliver high-quality public service.

        </p>

      </div>

    </div>

  </div>

</section>

<!-- ====================================================== -->
<!-- FEATURED GOVERNMENT TRAININGS -->
<!-- ====================================================== -->

<section class="py-24 bg-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        RECENT ENGAGEMENTS

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Workplace Effectiveness and Mental Wellbeing Training for Civil Servants

      </h2>

      <p class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto">

        HPCBI has successfully partnered with government institutions in Lagos
        State to deliver workplace wellbeing and professional development
        programmes that strengthen employee performance, resilience,
        collaboration and service delivery.

      </p>

    </div>

    <!-- ========================================== -->
    <!-- LAGOS STATE TREASURY OFFICE -->
    <!-- ========================================== -->

    <div class="grid lg:grid-cols-2 gap-16 items-center mt-24">

      <div>

        <img
          src="/images/gallery/treasury/1.jpg"
          alt="Lagos State Treasury Office Training"
          class="rounded-3xl shadow-2xl w-full h-[520px] object-cover object-center"
        />

      </div>

      <div>

        <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

          LAGOS STATE TREASURY OFFICE

        </p>

        <h3 class="mt-6 text-4xl font-bold text-slate-900">

          Workplace Effectiveness and Mental Wellbeing Training for Civil Servants

        </h3>

        <p class="mt-8 text-lg leading-9 text-gray-700">

          HPCBI facilitated an engaging and practical capacity-building workshop
          for staff of the Lagos State Treasury Office. The programme focused on
          strengthening workplace effectiveness while promoting the mental
          wellbeing of public servants through evidence-based approaches.

        </p>

        <p class="mt-6 text-lg leading-9 text-gray-700">

          Participants explored practical strategies for managing workplace
          stress, improving communication, strengthening teamwork and developing
          emotional intelligence to improve organisational performance.

        </p>

        <ul class="mt-8 space-y-4 text-lg text-gray-700">

          <li>✔ Workplace Mental Wellbeing</li>

          <li>✔ Emotional Intelligence</li>

          <li>✔ Stress Management</li>

          <li>✔ Effective Communication</li>

          <li>✔ Workplace Effectiveness</li>

        </ul>

        <div class="mt-10">

          <a
            href="/treasury-gallery"
            class="inline-flex items-center bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition"
          >

            View Gallery →

          </a>

        </div>

      </div>

    </div>

    <!-- ========================================== -->
    <!-- MINISTRY OF YOUTH & SOCIAL DEVELOPMENT -->
    <!-- ========================================== -->

    <div class="grid lg:grid-cols-2 gap-16 items-center mt-32">

      <div class="order-2 lg:order-1">

        <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

          MINISTRY OF YOUTH & SOCIAL DEVELOPMENT

        </p>

        <h3 class="mt-6 text-4xl font-bold text-slate-900">

          Workplace Effectiveness and Mental Wellbeing Training for Civil Servants

        </h3>

        <p class="mt-8 text-lg leading-9 text-gray-700">

          HPCBI also partnered with the Lagos State Ministry of Youth and Social
          Development to equip civil servants with practical workplace skills
          that improve wellbeing, productivity and organisational performance.

        </p>

        <p class="mt-6 text-lg leading-9 text-gray-700">

          Through interactive discussions and practical exercises,
          participants developed healthier approaches to workplace
          relationships, stress management, communication and teamwork.

        </p>

        <ul class="mt-8 space-y-4 text-lg text-gray-700">

          <li>✔ Workplace Mental Wellbeing</li>

          <li>✔ Emotional Intelligence</li>

          <li>✔ Team Collaboration</li>

          <li>✔ Conflict Management</li>

          <li>✔ Workplace Effectiveness</li>

        </ul>

        <div class="mt-10">

          <a
            href="/ministry-gallery-1"
            class="inline-flex items-center bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition"
          >

            View Gallery →

          </a>

        </div>

      </div>

      <div class="order-1 lg:order-2">

        <img
          src="/images/gallery/ministry-1/1.jpg"
          alt="Ministry of Youth and Social Development"
          class="rounded-3xl shadow-2xl w-full h-[520px] object-cover object-center"
        />

      </div>

    </div>

  </div>

</section>

<!-- ====================================================== -->
<!-- TRAINING IMPACT -->
<!-- ====================================================== -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        TRAINING IMPACT

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Outcomes of Our Capacity Building Programmes

      </h2>

      <p class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto">

        Every engagement is designed to improve workplace culture, employee
        wellbeing and institutional effectiveness through practical,
        evidence-based learning experiences.

      </p>

    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20">

          <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          📈

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Improved Productivity

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Participants gained practical workplace skills that improve
          productivity, efficiency and overall job performance.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🤝

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Better Teamwork

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Stronger collaboration, healthier communication and improved
          workplace relationships among colleagues.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🧠

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Healthier Workforce

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Greater awareness of mental wellbeing, stress management and
          emotional resilience within the public service.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🚀

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Organisational Excellence

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Practical strategies that contribute to improved service delivery
          and sustainable institutional growth.

        </p>

      </div>

    </div>

  </div>

</section>

<!-- ====================================================== -->
<!-- CALL TO ACTION -->
<!-- ====================================================== -->

<section class="py-24 bg-gradient-to-r from-green-700 to-blue-700">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <p class="uppercase tracking-[0.35em] text-green-200 font-semibold">

      PARTNER WITH HPCBI

    </p>

    <h2 class="mt-6 text-5xl font-bold text-white">

      Empower Your Workforce Through Capacity Building

    </h2>

    <p class="mt-8 text-xl leading-9 text-white">

      We partner with ministries, government agencies, educational
      institutions, NGOs and corporate organisations to deliver impactful,
      evidence-based training programmes that strengthen people,
      organisations and communities.

    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-6">

      <a
        href="/contact"
        class="bg-white text-green-700 px-10 py-4 rounded-xl font-bold hover:bg-gray-100 transition"
      >

        Request a Training

      </a>

      <a
        href="/gallery"
        class="bg-green-900 text-white px-10 py-4 rounded-xl font-bold hover:bg-green-800 transition"
      >

        View Our Gallery

      </a>

    </div>

  </div>

</section>

</Layout>