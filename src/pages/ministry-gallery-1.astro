---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Ministry of Youth and Social Development Training | HealthPsyche and CareBridge Initiatives">

<!-- HERO -->

<section
  class="relative h-[55vh] bg-cover bg-center"
  style="background-image:url('/images/gallery/ministry-1/1.jpg');"
>

  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 flex h-full items-center justify-center px-8">

    <div class="max-w-4xl text-center text-white">

      <p class="uppercase tracking-[0.35em] text-green-300 font-semibold">

        GOVERNMENT CAPACITY BUILDING

      </p>

      <h1 class="mt-6 text-5xl md:text-6xl font-extrabold">

        Ministry of Youth and Social Development Training

      </h1>

      <p class="mt-8 text-xl leading-9">

        Workplace Effectiveness and Mental Wellbeing Training
        for Civil Servants.

      </p>

    </div>

  </div>

</section>

<!-- INTRODUCTION -->

<section class="py-20 bg-white">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2 class="text-4xl font-bold text-slate-900">

      Building a More Effective Public Service

    </h2>

    <p class="mt-8 text-lg leading-9 text-gray-700">

      HealthPsyche and CareBridge Initiatives (HPCBI) delivered
      a Workplace Effectiveness and Mental Wellbeing training for
      staff of the Lagos State Ministry of Youth and Social
      Development. The programme focused on improving workplace
      wellbeing, emotional resilience, stress management,
      communication, teamwork and productivity within the public
      service.

    </p>

  </div>

</section>

<!-- IMPACT STATS -->

<section class="py-20 bg-green-700 text-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4 text-center">

      <div>

        <h3 class="text-5xl font-extrabold">

          Civil Servants

        </h3>

        <p class="mt-4 text-lg">

          Professional Development

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Workplace

        </h3>

        <p class="mt-4 text-lg">

          Mental Wellbeing

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Lagos State

        </h3>

        <p class="mt-4 text-lg">

          Ministry of Youth & Social Development

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Capacity

        </h3>

        <p class="mt-4 text-lg">

          Building Programme

        </p>

      </div>

    </div>

  </div>

</section>

<!-- PHOTO GALLERY -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center mb-16">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        PHOTO GALLERY

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Ministry Training Highlights

      </h2>

      <p class="mt-6 text-lg text-gray-600">

        Six moments captured during the Workplace Effectiveness
        and Mental Wellbeing training programme.

      </p>

    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      <a href="/images/gallery/ministry-1/1.jpg">
        <img
          src="/images/gallery/ministry-1/1.jpg"
          alt="Ministry Training Photo 1"
          class="rounded-3xl shadow-xl w-full h-80 object-cover object-center hover:scale-105 transition duration-300"
        />
      </a>

      <a href="/images/gallery/ministry-1/2.jpg">
        <img
          src="/images/gallery/ministry-1/2.jpg"
          alt="Ministry Training Photo 2"
          class="rounded-3xl shadow-xl w-full h-80 object-cover object-center hover:scale-105 transition duration-300"
        />
      </a>

      <a href="/images/gallery/ministry-1/3.jpg">
        <img
          src="/images/gallery/ministry-1/3.jpg"
          alt="Ministry Training Photo 3"
          class="rounded-3xl shadow-xl w-full h-80 object-cover object-center hover:scale-105 transition duration-300"
        />
      </a>

      <a href="/images/gallery/ministry-1/4.jpg">
        <img
          src="/images/gallery/ministry-1/4.jpg"
          alt="Ministry Training Photo 4"
          class="rounded-3xl shadow-xl w-full h-80 object-cover object-center hover:scale-105 transition duration-300"
        />
      </a>

      <a href="/images/gallery/ministry-1/5.jpg">
        <img
          src="/images/gallery/ministry-1/5.jpg"
          alt="Ministry Training Photo 5"
          class="rounded-3xl shadow-xl w-full h-80 object-cover object-center hover:scale-105 transition duration-300"
        />
      </a>

      <a href="/images/gallery/ministry-1/6.jpg">
        <img
          src="/images/gallery/ministry-1/6.jpg"
          alt="Ministry Training Photo 6"
          class="rounded-3xl shadow-xl w-full h-80 object-cover object-center hover:scale-105 transition duration-300"
        />
      </a>

    </div>

  </div>

</section>

<!-- NAVIGATION -->

<section class="py-20 bg-white">

  <div class="max-w-6xl mx-auto px-8">

    <div class="flex flex-wrap justify-between gap-6">

      <a
        href="/treasury-gallery"
        class="bg-slate-800 text-white px-8 py-4 rounded-xl font-bold hover:bg-slate-900 transition"
      >

        ← Treasury Gallery

      </a>

      <a
        href="/gallery"
        class="bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition"
      >

        Back to Gallery →

      </a>

    </div>

  </div>

</section>

</Layout>