---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us | HealthPsyche and CareBridge Initiatives">

<!-- HERO SECTION -->

<section
  class="relative h-[75vh] bg-cover bg-center"
  style="background-image:url('/images/hero/hero-school.jpg');"
>

  <div class="absolute inset-0 bg-black/65"></div>

  <div
    class="relative z-10 h-full flex items-center justify-center px-8"
  >

    <div class="max-w-5xl text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-300 font-semibold mb-6"
      >

        ABOUT HEALTHPSYCHE AND CAREBRIDGE INITIATIVES

      </p>

      <h1
        class="text-5xl md:text-7xl font-extrabold text-white leading-tight"
      >

        Building

        Healthier Communities

        Through

        <span class="text-green-300">

          Mental Wellbeing

        </span>

      </h1>

      <p
        class="mt-10 text-xl text-white leading-10"
      >

        Improving lives through mental wellbeing,
        public health, inclusive education,
        innovation and strategic partnerships.

      </p>

    </div>

  </div>

</section>

<!-- OUR STORY -->

<section class="py-24 bg-white">

  <div
    class="max-w-6xl mx-auto px-8 text-center"
  >

    <h2
      class="text-5xl font-bold text-slate-900"
    >

      Our Story

    </h2>

    <p
      class="mt-10 text-lg leading-9 text-gray-700"
    >

      HealthPsyche and CareBridge Initiatives (HPCBI) is a
      nonprofit organisation committed to improving lives
      through mental wellbeing promotion, public health
      education, inclusive learning and youth empowerment.
      We believe that healthier minds create stronger
      communities and that every individual deserves the
      opportunity to thrive regardless of background or
      ability.

    </p>

    <p
      class="mt-8 text-lg leading-9 text-gray-700"
    >

      Through partnerships with schools, government
      institutions, community leaders and development
      partners, we deliver practical programmes that
      improve wellbeing, strengthen resilience, promote
      healthy lifestyles and prepare young people with the
      knowledge and digital skills needed for the future.

    </p>

  </div>

</section>

<!-- VISION • MISSION • VALUES -->

<section class="py-24 bg-slate-50">

  <div
    class="max-w-7xl mx-auto px-8"
  >

    <div class="text-center">

      <h2
        class="text-5xl font-bold text-slate-900"
      >

        Vision, Mission & Core Values

      </h2>

      <p
        class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
      >

        Our work is guided by a clear vision,
        a purposeful mission and values that shape
        every programme and partnership.

      </p>

    </div>

    <div
      class="grid lg:grid-cols-3 gap-10 mt-20"
    >

      <!-- Vision -->

      <div
        class="bg-white rounded-3xl shadow-xl p-10"
      >

        <div class="text-5xl">

          🌍

        </div>

        <h3
          class="mt-6 text-3xl font-bold"
        >

          Our Vision

        </h3>

        <p
          class="mt-6 leading-8 text-gray-600"
        >

          A society where individuals and communities
          enjoy better mental wellbeing, quality health,
          equal opportunities and the knowledge needed to
          build brighter futures.

        </p>

      </div>

      <!-- Mission -->
    

      <div
        class="bg-white rounded-3xl shadow-xl p-10"
      >

        <div class="text-5xl">

          🎯

        </div>

        <h3
          class="mt-6 text-3xl font-bold"
        >

          Our Mission

        </h3>

        <p
          class="mt-6 leading-8 text-gray-600"
        >

          To improve mental wellbeing, strengthen public
          health, promote inclusive education and empower
          communities through innovative programmes,
          strategic partnerships and evidence-based
          interventions that create lasting positive impact.

        </p>

      </div>

      <!-- Core Values -->

      <div
        class="bg-white rounded-3xl shadow-xl p-10"
      >

        <div class="text-5xl">

          ❤️

        </div>

        <h3
          class="mt-6 text-3xl font-bold"
        >

          Our Core Values

        </h3>

        <ul
          class="mt-6 space-y-4 text-left text-gray-600 leading-8"
        >

          <li>✔ Compassion</li>

          <li>✔ Integrity</li>

          <li>✔ Inclusion</li>

          <li>✔ Innovation</li>

          <li>✔ Collaboration</li>

          <li>✔ Excellence</li>

        </ul>

      </div>

    </div>

  </div>

</section>

<!-- OUR AREAS OF IMPACT -->

<section class="py-24 bg-white">

  <div
    class="max-w-7xl mx-auto px-8"
  >

    <div class="text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-600 font-semibold"
      >

        WHAT WE DO

      </p>

      <h2
        class="mt-6 text-5xl font-bold text-slate-900"
      >

        Our Areas of Impact

      </h2>

      <p
        class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
      >

        We design and implement programmes that improve
        lives, strengthen communities and prepare people
        for healthier and more productive futures.

      </p>

    </div>

    <div
      class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20"
    >

      <div class="bg-slate-50 rounded-3xl shadow-lg p-10 text-center">

        <div class="text-5xl">

          🧠

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Mental Wellbeing

        </h3>

        <p class="mt-5 leading-8 text-gray-600">

          Promoting emotional wellbeing, resilience and
          psychological health in schools, workplaces and
          communities.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl shadow-lg p-10 text-center">

        <div class="text-5xl">

          🏫

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Education

        </h3>

        <p class="mt-5 leading-8 text-gray-600">

          Delivering school-based programmes that equip
          students with life skills, confidence and
          opportunities for lifelong learning.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl shadow-lg p-10 text-center">

        <div class="text-5xl">

          💻

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          AI & Digital Skills

        </h3>

        <p class="mt-5 leading-8 text-gray-600">

          Preparing young people with Artificial
          Intelligence literacy and practical digital
          skills for the future of work.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl shadow-lg p-10 text-center">

        <div class="text-5xl">

          🤝

        </div>

        <h3 class="mt-6 text-2xl font-bold">

          Community Development

        </h3>

        <p class="mt-5 leading-8 text-gray-600">

          Working alongside communities and partners to
          improve health, inclusion and sustainable
          development.

        </p>

      </div>

    </div>

  </div>

</section>

<!-- SUSTAINABLE DEVELOPMENT GOALS -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-600 font-semibold"
      >

        OUR GLOBAL COMMITMENT

      </p>

      <h2
        class="mt-6 text-5xl font-bold text-slate-900"
      >

        Contributing to the Sustainable Development Goals

      </h2>

      <p
        class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
      >

        Our programmes support the United Nations Sustainable
        Development Goals by promoting health, education,
        inclusion and partnerships that create lasting
        community impact.

      </p>

    </div>

    <div
      class="grid md:grid-cols-2 lg:grid-cols-5 gap-8 mt-20"
    >

      <div class="bg-white rounded-3xl shadow-lg p-8 text-center">

        <div class="text-5xl">❤️</div>

        <h3 class="mt-5 text-xl font-bold">

          SDG 3

        </h3>

        <p class="mt-3 text-gray-600">

          Good Health & Well-being

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-lg p-8 text-center">

        <div class="text-5xl">📚</div>

        <h3 class="mt-5 text-xl font-bold">

          SDG 4

        </h3>

        <p class="mt-3 text-gray-600">

          Quality Education

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-lg p-8 text-center">

        <div class="text-5xl">⚖️</div>

        <h3 class="mt-5 text-xl font-bold">

          SDG 10

        </h3>

        <p class="mt-3 text-gray-600">

          Reduced Inequalities

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-lg p-8 text-center">

        <div class="text-5xl">🏙️</div>

        <h3 class="mt-5 text-xl font-bold">

          SDG 11

        </h3>

        <p class="mt-3 text-gray-600">

          Sustainable Communities

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-lg p-8 text-center">

        <div class="text-5xl">🤝</div>

        <h3 class="mt-5 text-xl font-bold">

          SDG 17

        </h3>

        <p class="mt-3 text-gray-600">

          Partnerships for the Goals

        </p>

      </div>

    </div>

  </div>

</section>

<!-- WHY PARTNER WITH HPCBI -->

<section class="py-24 bg-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <h2
        class="text-5xl font-bold text-slate-900"
      >

        Why Partner With HPCBI

      </h2>

      <p
        class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
      >

        We believe meaningful change happens through
        collaboration. By partnering with government,
        schools, businesses, foundations and development
        organisations, we deliver sustainable programmes
        that improve lives and strengthen communities.

      </p>

    </div>

    <div
      class="grid md:grid-cols-2 lg:grid-cols-3 gap-10 mt-20"
    >

      <div class="bg-slate-50 rounded-3xl p-10 shadow-lg">

        <h3 class="text-2xl font-bold">

          Evidence-Based Programmes

        </h3>

        <p class="mt-6 text-gray-600 leading-8">

          Our interventions are designed using research,
          practical experience and measurable outcomes.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl p-10 shadow-lg">

        <h3 class="text-2xl font-bold">

          Strong Partnerships

        </h3>

        <p class="mt-6 text-gray-600 leading-8">

          We collaborate with schools, government agencies,
          community leaders and development partners.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl p-10 shadow-lg">

        <h3 class="text-2xl font-bold">

          Sustainable Impact

        </h3>

        <p class="mt-6 text-gray-600 leading-8">

          Our goal is to create lasting improvements in
          health, education and community wellbeing.

        </p>

      </div>

    </div>

  </div>

</section>

<!-- LEADERSHIP -->

<section class="py-24 bg-slate-50">

  <div class="max-w-6xl mx-auto px-8 text-center">

    <h2
      class="text-5xl font-bold text-slate-900"
    >

      Leadership & Governance

    </h2>

    <p
      class="mt-8 text-lg leading-9 text-gray-700"
    >

      HealthPsyche and CareBridge Initiatives is governed
      by a dedicated Board of Directors and supported by
      professionals who are passionate about improving
      health, education and community wellbeing.

    </p>

    <div
      class="mt-16 bg-white rounded-3xl shadow-xl p-12"
    >

      <h3
        class="text-3xl font-bold"
      >

        Board of Directors

      </h3>

      <p
        class="mt-6 text-gray-600 leading-9"
      >

        Information about the Board of Directors and
        leadership team will be published here as the
        organisation continues to grow.

      </p>

    </div>

  </div>

</section>

<!-- CALL TO ACTION -->

<section
  class="py-24 bg-gradient-to-r from-green-600 to-blue-700"
>

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2
      class="text-5xl font-bold text-white"
    >

      Together We Can Build Healthier Communities

    </h2>

    <p
      class="mt-8 text-xl text-white leading-9"
    >

      Join us in promoting mental wellbeing, improving
      public health, advancing inclusive education and
      empowering communities through sustainable
      partnerships.

    </p>

    <div
      class="mt-12 flex flex-wrap justify-center gap-6"
    >

      <a
        href="/contact"
        class="bg-white text-green-700 font-bold px-10 py-4 rounded-xl hover:bg-gray-100 transition"
      >

        Contact Us

      </a>

      <a
        href="/support-our-mission"
        class="bg-green-900 text-white font-bold px-10 py-4 rounded-xl hover:bg-green-800 transition"
      >

        Support Our Mission

      </a>

    </div>

  </div>

</section>

</Layout>