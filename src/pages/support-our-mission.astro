---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Support Our Mission | HealthPsyche and CareBridge Initiatives">

<!-- HERO -->

<section
  class="relative h-[75vh] bg-cover bg-center"
  style="background-image:url('/images/hero/hero-school.jpg');"
>

  <div class="absolute inset-0 bg-black/70"></div>

  <div
    class="relative z-10 h-full flex items-center justify-center px-8"
  >

    <div class="max-w-5xl text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-300 font-semibold mb-6"
      >

        SUPPORT OUR MISSION

      </p>

      <h1
        class="text-5xl md:text-7xl font-extrabold text-white leading-tight"
      >

        Together We Can Build

        <span class="text-green-300">

          Healthier Communities

        </span>

      </h1>

      <p
        class="mt-10 text-xl text-white leading-10"
      >

        Your support enables HealthPsyche and CareBridge
        Initiatives (HPCBI) to reach more schools,
        strengthen communities and improve lives through
        mental wellbeing, public health and digital
        education.

      </p>

    </div>

  </div>

</section>


<!-- DONATION DETAILS -->
<section class="py-24 bg-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-600 font-semibold"
      >

        DONATE TODAY

      </p>

      <h2
        class="mt-6 text-5xl font-bold text-slate-900"
      >

        Choose Your Preferred Donation Method

      </h2>

      <p
        class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
      >

        We welcome support from individuals, organisations,
        foundations and corporate partners around the world.
        Every contribution helps us expand our impact and
        reach more people.

      </p>

    </div>

    <div
      class="grid lg:grid-cols-2 gap-10 mt-20"
    >

      <!-- USD ACCOUNT -->

      <div
        class="rounded-3xl border-2 border-green-600 shadow-2xl p-10 bg-gradient-to-br from-green-50 to-white"
      >

        <div class="flex items-center gap-4">

          <span class="text-5xl">

            🌍

          </span>

          <div>

            <h3 class="text-3xl font-bold">

              US Dollar Account

            </h3>

            <p class="text-green-700 font-semibold">

              International Donations

            </p>

          </div>

        </div>

        <div class="mt-10 space-y-6 text-lg">

          <div>

            <span class="font-bold">

              Bank

            </span>

            <br>

            Zenith Bank

          </div>

          <div>

            <span class="font-bold">

              Account Name

            </span>

            <br>

            HealthPsyche and CareBridge Initiatives

          </div>

          <div>

            <span class="font-bold">

              Account Number

            </span>

            <br>

            <span
              id="usdAccount"
              class="text-2xl font-extrabold tracking-widest text-green-700"
            >

              5076116583

            </span>

          </div>

          <div>

            <span class="font-bold">

              Currency

            </span>

            <br>

            USD

          </div>

          <div>

            <span class="font-bold">

              SWIFT / BIC

            </span>

            <br>

            ZEIBNGLAXXX

          </div>

        </div>

        <button
          onclick="copyUSDAccount()"
          class="mt-10 w-full bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 transition"
        >

          Copy Dollar Account Number

        </button>

      </div>

      <!-- NAIRA ACCOUNT -->

      <div
        class="rounded-3xl border-2 border-blue-600 shadow-2xl p-10 bg-gradient-to-br from-blue-50 to-white"
      >

        <div class="flex items-center gap-4">

          <span class="text-5xl">

            🇳🇬

          </span>

          <div>

            <h3 class="text-3xl font-bold">

              Nigerian Naira Account

            </h3>

            <p class="text-blue-700 font-semibold">

              Local Donations

            </p>

          </div>

        </div>

        <div class="mt-10 space-y-6 text-lg">

          <div>

            <span class="font-bold">

              Bank

            </span>

            <br>

            Zenith Bank

          </div>

          <div>

            <span class="font-bold">

              Account Name

            </span>

            <br>

            HealthPsyche and CareBridge Initiatives

          </div>

          <div>

            <span class="font-bold">

              Account Number

            </span>

            <br>

            <span
              id="ngnAccount"
              class="text-2xl font-extrabold tracking-widest text-blue-700"
            >

              1311745321

            </span>

          </div>

          <div>

            <span class="font-bold">

              Currency

            </span>

            <br>

            NGN

          </div>

        </div>

        <button
          onclick="copyNGNAccount()"
          class="mt-10 w-full bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-blue-700 transition"
        >

          Copy Naira Account Number

        </button>

      </div>

    </div>

  </div>

</section>

<!-- THANK YOU -->
<section class="py-24 bg-slate-50">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <div class="text-6xl">

      ❤️

    </div>

    <h2
      class="mt-8 text-5xl font-bold text-slate-900"
    >

      Thank You for Investing in Healthier Communities

    </h2>

    <p
      class="mt-10 text-lg leading-9 text-gray-700"
    >

      Every contribution, whether large or small, helps
      HealthPsyche and CareBridge Initiatives (HPCBI)
      improve lives through mental wellbeing, public
      health, inclusive education and Artificial
      Intelligence literacy programmes.

    </p>

    <p
      class="mt-8 text-lg leading-9 text-gray-700"
    >

      Together, we can create healthier schools,
      stronger communities and brighter futures for
      children, young people and families.

    </p>

  </div>

</section>

<!-- WHY YOUR SUPPORT MATTERS -->

<section class="py-24 bg-white">

  <div class="max-w-6xl mx-auto px-8 text-center">

    <p
      class="uppercase tracking-[0.35em] text-green-600 font-semibold"
    >

      MAKE AN IMPACT

    </p>

    <h2
      class="mt-6 text-5xl font-bold text-slate-900"
    >

      Every Contribution Makes a Difference

    </h2>

    <p
      class="mt-10 text-lg leading-9 text-gray-700"
    >

      Every donation, sponsorship and partnership helps us
      expand our programmes, reach underserved communities
      and empower more young people with knowledge, skills
      and opportunities that improve their future.

    </p>

  </div>

</section>

<!-- YOUR SUPPORT HELPS US -->
<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-600 font-semibold"
      >

        YOUR IMPACT

      </p>

      <h2
        class="mt-6 text-5xl font-bold text-slate-900"
      >

        Your Support Helps Us

      </h2>

      <p
        class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
      >

        Every contribution directly supports programmes
        that improve lives, strengthen communities and
        prepare young people for healthier and brighter
        futures.

      </p>

    </div>

    <div
      class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20"
    >

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🧠</div>

        <h3 class="mt-6 text-2xl font-bold">

          Mental Wellbeing

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Deliver mental health awareness and wellbeing
          programmes in schools and communities.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🏫</div>

        <h3 class="mt-6 text-2xl font-bold">

          School Outreach

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Expand the Healthy Minds, Brighter Futures
          programme to more public secondary schools.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🤟</div>

        <h3 class="mt-6 text-2xl font-bold">

          Inclusive Education

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Support programmes for deaf and
          hard-of-hearing learners and promote
          inclusive learning opportunities.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">💻</div>

        <h3 class="mt-6 text-2xl font-bold">

          AI & Digital Skills

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Equip young people with future-ready
          technology and digital innovation skills.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">👥</div>

        <h3 class="mt-6 text-2xl font-bold">

          Community Outreach

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Deliver health education and community
          engagement programmes across Lagos State.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">📚</div>

        <h3 class="mt-6 text-2xl font-bold">

          Learning Resources

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Produce educational materials, guides and
          practical learning tools for beneficiaries.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🚌</div>

        <h3 class="mt-6 text-2xl font-bold">

          Logistics

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Support transportation, equipment and
          operational costs for outreach programmes.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">🤝</div>

        <h3 class="mt-6 text-2xl font-bold">

          Partnerships

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Build sustainable collaborations that
          expand our reach and long-term impact.

        </p>

      </div>

    </div>

  </div>

</section>


<!-- ORGANISATIONS & FOUNDATIONS -->

<section class="py-24 bg-white">

  <div class="max-w-6xl mx-auto px-8 text-center">

    <p
      class="uppercase tracking-[0.35em] text-green-600 font-semibold"
    >

      PARTNERSHIPS

    </p>

    <h2
      class="mt-6 text-5xl font-bold text-slate-900"
    >

      Looking to Support as an Organisation?

    </h2>

    <p
      class="mt-10 text-lg leading-9 text-gray-700 max-w-4xl mx-auto"
    >

      We welcome partnerships with foundations,
      corporate organisations, government agencies,
      donor organisations, educational institutions
      and philanthropists who share our vision of
      building healthier communities through
      education, innovation and wellbeing.

    </p>

    <div
      class="mt-14 flex flex-wrap justify-center gap-6"
    >

      <a
        href="/contact"
        class="bg-green-600 text-white font-bold px-10 py-4 rounded-xl hover:bg-green-700 transition"
      >

        Support Our Mission

      </a>

      <a
        href="mailto:info@hpcbi.org"
        class="border-2 border-green-600 text-green-700 font-bold px-10 py-4 rounded-xl hover:bg-green-50 transition"
      >

        Email Us

      </a>

    </div>

  </div>

</section>

<!-- DONATION RECEIPT -->

<section class="py-24 bg-slate-900 text-white">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2
      class="text-5xl font-bold"
    >

      Need a Donation Receipt?

    </h2>

    <p
      class="mt-10 text-xl leading-9 text-slate-300"
    >

      If you require an acknowledgement or receipt for
      your donation, please contact us with your payment
      details. We will be pleased to assist you.

    </p>

    <div
      class="mt-12 flex flex-wrap justify-center gap-6"
    >

      <a
        href="/contact"
        class="bg-green-500 text-black font-bold px-10 py-4 rounded-xl hover:bg-green-400 transition"
      >

        Contact HPCBI

      </a>

    </div>

  </div>

</section>

<script>
function copyUSDAccount() {
  navigator.clipboard.writeText("5076116583");
  alert("US Dollar account number copied successfully.");
}

function copyNGNAccount() {
  navigator.clipboard.writeText("1311745321");
  alert("Naira account number copied successfully.");
}
</script>

</Layout>