---
import Layout from "../layouts/Layout.astro";
---

<Layout title="News & Stories | HealthPsyche and CareBridge Initiatives">

<!-- ===================================== -->
<!-- HERO -->
<!-- ===================================== -->

<section
  class="relative h-[65vh] bg-cover bg-center"
  style="background-image:url('/images/hero/hero-school.jpg');"
>

  <div class="absolute inset-0 bg-black/65"></div>

  <div
    class="relative z-10 h-full flex items-center justify-center px-8"
  >

    <div class="max-w-5xl text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-300 font-semibold mb-6"
      >

        NEWS & STORIES

      </p>

      <h1
        class="text-5xl md:text-7xl font-extrabold text-white leading-tight"
      >

        Latest News,

        <span class="text-green-300">

          Stories & Impact

        </span>

      </h1>

      <p
        class="mt-10 text-xl text-white leading-10"
      >

        Discover how HealthPsyche and CareBridge Initiatives
        is transforming lives through mental wellbeing,
        public health, inclusive education and community
        development across Nigeria.

      </p>

    </div>

  </div>

</section>

<!-- ===================================== -->
<!-- INTRODUCTION -->
<!-- ===================================== -->

<section class="py-24 bg-white">

  <div class="max-w-6xl mx-auto px-8 text-center">

    <h2
      class="text-5xl font-bold text-slate-900"
    >

      Stories That Inspire Change

    </h2>

    <p
      class="mt-10 text-lg leading-9 text-gray-700"
    >

      Every programme we implement represents a step toward
      healthier minds, stronger communities and brighter
      futures. Here you'll find updates from our school
      outreach programmes, government trainings, community
      engagement initiatives and other activities that are
      creating measurable impact.

    </p>

  </div>

</section>

<!-- ===================================== -->
<!-- FEATURED STORY -->
<!-- ===================================== -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p
        class="uppercase tracking-[0.35em] text-green-600 font-semibold"
      >

        FEATURED STORY

      </p>

      <h2
        class="mt-6 text-5xl font-bold text-slate-900"
      >

        Healthy Minds, Brighter Futures Continues to Transform Schools

      </h2>

    </div>

    <div
      class="grid lg:grid-cols-2 gap-16 items-center mt-20"
    >

      <div>

        <img
          src="/images/gallery/school-1/1.jpg"
          alt="Healthy Minds Brighter Futures"
          class="rounded-3xl shadow-2xl w-full h-[500px] object-cover object-center"
        />

      </div>

      <div>

        <p
          class="uppercase tracking-[0.35em] text-green-600 font-semibold"
        >

          SCHOOL IMPACT

        </p>

        <h3
          class="mt-6 text-4xl font-bold text-slate-900"
        >

          Healthy Minds, Brighter Futures Reaches More Schools Across Lagos

        </h3>

        <p
          class="mt-8 text-lg leading-9 text-gray-700"
        >

          Through our flagship <strong>Healthy Minds, Brighter Futures</strong>
          programme, HealthPsyche and CareBridge Initiatives (HPCBI)
          continues to equip students with practical knowledge on
          mental wellbeing, emotional resilience, healthy relationships,
          life skills and future-ready digital awareness.

        </p>

        <p
          class="mt-6 text-lg leading-9 text-gray-700"
        >

          The programme has reached several public secondary schools,
          including inclusive schools for learners with hearing
          impairments, helping young people build confidence,
          resilience and the skills needed to thrive academically
          and socially.

        </p>

        <div class="mt-10">

          <a
            href="/school-impact"
            class="inline-flex items-center bg-green-600 hover:bg-green-700 text-white font-bold px-8 py-4 rounded-xl transition"
          >

            Read More →

          </a>

        </div>

      </div>

    </div>

  </div>

</section>

<!-- NEWS ARTICLES -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        RECENT STORIES

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Latest News & Activities

      </h2>

      <p class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto">

        Stay informed about our latest programmes, community
        engagements, partnerships and impact stories across
        Nigeria.

      </p>

    </div>

    <div class="grid lg:grid-cols-3 gap-10 mt-20">

      <!-- Story 1 -->

      <article class="bg-white rounded-3xl shadow-xl overflow-hidden">

        <img
          src="/images/gallery/school-1/1.jpg"
          alt="School Outreach"
          class="w-full h-72 object-cover"
        />

        <div class="p-8">

          <span class="text-green-600 font-semibold">

            School Outreach

          </span>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            Healthy Minds, Brighter Futures Programme Reaches More Schools

          </h3>

          <p class="mt-5 text-gray-700 leading-8">

            HPCBI continued its school-based mental wellbeing
            programme by engaging students across Lagos State
            with practical sessions on resilience, emotional
            wellbeing and healthy life choices.

          </p>

          <a
            href="/school-impact"
            class="inline-block mt-8 text-green-700 font-bold hover:text-green-900"
          >

            Read More →

          </a>

        </div>

      </article>

      <!-- Story 2 -->

      <article class="bg-white rounded-3xl shadow-xl overflow-hidden">

        <img
          src="/images/gallery/treasury/1.jpg"
          alt="Treasury Office Training"
          class="w-full h-72 object-cover"
        />

        <div class="p-8">

          <span class="text-green-600 font-semibold">

            Government Capacity Building

          </span>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            Workplace Effectiveness & Mental Wellbeing Training

          </h3>

          <p class="mt-5 text-gray-700 leading-8">

            Civil servants of the Lagos State Treasury Office
            participated in a practical training focused on
            emotional intelligence, workplace wellbeing,
            communication and productivity.

          </p>

          <a
            href="/treasury-gallery"
            class="inline-block mt-8 text-green-700 font-bold hover:text-green-900"
          >

            Read More →

          </a>

        </div>

      </article>

      <!-- Story 3 -->

      <article class="bg-white rounded-3xl shadow-xl overflow-hidden">

        <img
          src="/images/gallery/ministry-1/1.jpg"
          alt="Ministry Training"
          class="w-full h-72 object-cover"
        />

        <div class="p-8">

          <span class="text-green-600 font-semibold">

            Government Partnership

          </span>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            Ministry Staff Receive Workplace Wellbeing Training

          </h3>

          <p class="mt-5 text-gray-700 leading-8">

            Staff of the Ministry of Youth and Social
            Development participated in our Workplace
            Effectiveness and Mental Wellbeing programme,
            promoting healthier and more productive public
            institutions.

          </p>

          <a
            href="/ministry-gallery-1"
            class="inline-block mt-8 text-green-700 font-bold hover:text-green-900"
          >

            Read More →

          </a>

        </div>

      </article>

    </div>

  </div>

</section>

<!-- MEDIA & PUBLICATIONS -->

<section class="py-24 bg-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        MEDIA & PUBLICATIONS

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Sharing Knowledge. Inspiring Change.

      </h2>

      <p class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto">

        Beyond our programmes, HPCBI is committed to sharing
        practical knowledge through articles, reports,
        advocacy campaigns and educational resources that
        promote mental wellbeing, public health and
        community development.

      </p>

    </div>

    <div class="grid md:grid-cols-3 gap-8 mt-20">

      <div class="bg-slate-50 rounded-3xl p-10 shadow-lg">

        <div class="text-5xl mb-6">

          📰

        </div>

        <h3 class="text-2xl font-bold">

          News Updates

        </h3>

        <p class="mt-5 text-gray-700 leading-8">

          Stay informed about our latest programmes,
          partnerships, trainings and community outreach
          activities.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl p-10 shadow-lg">

        <div class="text-5xl mb-6">

          📖

        </div>

        <h3 class="text-2xl font-bold">

          Articles

        </h3>

        <p class="mt-5 text-gray-700 leading-8">

          Expert insights on mental health, public health,
          AI education, leadership and community
          development.

        </p>

      </div>

      <div class="bg-slate-50 rounded-3xl p-10 shadow-lg">

        <div class="text-5xl mb-6">

          📊

        </div>

        <h3 class="text-2xl font-bold">

          Reports

        </h3>

        <p class="mt-5 text-gray-700 leading-8">

          Programme highlights, impact reports and success
          stories demonstrating the lives and communities
          reached through our interventions.

        </p>

      </div>

    </div>

  </div>

</section>

<!-- STAY UPDATED -->

<section class="py-24 bg-gradient-to-r from-green-700 to-green-900">

  <div class="max-w-4xl mx-auto px-8 text-center">

    <h2 class="text-5xl font-bold text-white">

      Stay Connected With HPCBI

    </h2>

    <p class="mt-8 text-xl leading-9 text-white">

      Follow our journey as we continue promoting healthier
      minds, stronger communities and brighter futures
      across Nigeria.

    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-6">

      <a
        href="/gallery"
        class="bg-white text-green-700 font-bold px-10 py-4 rounded-xl hover:bg-gray-100 transition"
      >

        View Gallery

      </a>

      <a
        href="/contact"
        class="bg-green-900 text-white font-bold px-10 py-4 rounded-xl hover:bg-green-800 transition"
      >

        Contact Us

      </a>

    </div>

  </div>

</section>

<!-- CALL TO ACTION -->

<section class="py-24 bg-slate-100">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2 class="text-5xl font-bold text-slate-900">

      Partner With Us

    </h2>

    <p class="mt-8 text-lg leading-9 text-gray-700">

      Whether you are a government institution, school,
      corporate organisation, donor or volunteer, we invite
      you to work with HealthPsyche and CareBridge
      Initiatives to build healthier minds and stronger
      communities.

    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-6">

      <a
        href="/support-our-mission"
        class="bg-green-600 text-white font-bold px-10 py-4 rounded-xl hover:bg-green-700 transition"
      >

        Support Our Mission

      </a>

      <a
        href="/contact"
        class="border-2 border-green-600 text-green-700 font-bold px-10 py-4 rounded-xl hover:bg-green-600 hover:text-white transition"
      >

        Get in Touch

      </a>

    </div>

  </div>

</section>

</Layout>

