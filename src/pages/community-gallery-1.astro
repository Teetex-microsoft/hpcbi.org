---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Community Mental Health Gallery | HealthPsyche and CareBridge Initiatives">

<!-- HERO -->

<section
  class="relative h-[55vh] bg-cover bg-center"
  style="background-image:url('/images/gallery/community-1/1.jpg');"
>

  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 flex h-full items-center justify-center px-8">

    <div class="max-w-4xl text-center text-white">

      <p class="uppercase tracking-[0.35em] text-green-300 font-semibold">

        COMMUNITY MENTAL HEALTH

      </p>

      <h1 class="mt-6 text-5xl md:text-6xl font-extrabold">

        Community Mental Health Gallery

      </h1>

      <p class="mt-8 text-xl leading-9">

        Bringing mental health awareness, education and hope directly to
        communities through engagement, advocacy and public health outreach.

      </p>

    </div>

  </div>

</section>

<!-- INTRODUCTION -->

<section class="py-20 bg-white">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2 class="text-4xl font-bold text-slate-900">

      Empowering Communities

    </h2>

    <p class="mt-8 text-lg leading-9 text-gray-700">

      HealthPsyche and CareBridge Initiatives is committed to improving
      community wellbeing by increasing awareness of mental health,
      reducing stigma, encouraging early help-seeking and promoting
      healthier lifestyles through community-based programmes.

    </p>

  </div>

</section>

<!-- IMPACT STATS -->

<section class="py-20 bg-green-700 text-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4 text-center">

      <div>

        <h3 class="text-5xl font-extrabold">

          Community

        </h3>

        <p class="mt-4 text-lg">

          Mental Health Outreach

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Awareness

        </h3>

        <p class="mt-4 text-lg">

          Education & Advocacy

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Public

        </h3>

        <p class="mt-4 text-lg">

          Health Promotion

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Stronger

        </h3>

        <p class="mt-4 text-lg">

          Healthier Communities

        </p>

      </div>

    </div>

  </div>

</section>

<!-- PHOTO GALLERY -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center mb-16">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        PHOTO GALLERY

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        Community Mental Health Outreach

      </h2>

      <p class="mt-6 text-lg text-gray-600">

        Six moments captured during this community outreach programme.

      </p>

    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      <a href="/images/gallery/community-1/1.jpg">

        <img
          src="/images/gallery/community-1/1.jpg"
          alt="Community Outreach Photo 1"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/community-1/2.jpg">

        <img
          src="/images/gallery/community-1/2.jpg"
          alt="Community Outreach Photo 2"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/community-1/3.jpg">

        <img
          src="/images/gallery/community-1/3.jpg"
          alt="Community Outreach Photo 3"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/community-1/4.jpg">

        <img
          src="/images/gallery/community-1/4.jpg"
          alt="Community Outreach Photo 4"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/community-1/5.jpg">

        <img
          src="/images/gallery/community-1/5.jpg"
          alt="Community Outreach Photo 5"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/community-1/6.jpg">

        <img
          src="/images/gallery/community-1/6.jpg"
          alt="Community Outreach Photo 6"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

    </div>

  </div>

</section>

<!-- NAVIGATION -->

<section class="py-20 bg-white">

  <div class="max-w-6xl mx-auto px-8">

    <div class="flex flex-wrap justify-between gap-6">

      <a
        href="/gallery"
        class="bg-slate-800 text-white px-8 py-4 rounded-xl font-bold hover:bg-slate-900 transition"
      >

        ← Back to Gallery

      </a>

      <a
        href="/community-mental-health"
        class="bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition"
      >

        Community Programme →

      </a>

    </div>

  </div>

</section>

</Layout>