---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gallery | HealthPsyche and CareBridge Initiatives">

<!-- HERO -->
<section
  class="relative h-[60vh] bg-cover bg-center"
  style="background-image: url('/images/gallery/gallery-hero.jpg');"
>
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 flex h-full items-center justify-center px-6">
    <div class="max-w-4xl text-center text-white">

      <p class="uppercase tracking-[0.35em] text-green-300 font-semibold">
        OUR GALLERY
      </p>

      <h1 class="mt-6 text-5xl md:text-7xl font-extrabold">
        Capturing
        <span class="text-green-300">Impact</span>
      </h1>

      <p class="mt-8 text-xl leading-9">
        Explore highlights from HealthPsyche and CareBridge Initiatives'
        programmes across schools, government institutions and communities
        in Lagos State.
      </p>

    </div>
  </div>
</section>

<!-- INTRODUCTION -->

<section class="py-20 bg-white">

  <div class="max-w-5xl mx-auto px-6 text-center">

    <h2 class="text-4xl font-bold text-slate-900">
      Moments That Inspire Change
    </h2>

    <p class="mt-8 text-lg leading-9 text-gray-700">
      These photographs reflect our commitment to promoting mental wellbeing,
      strengthening communities, supporting education and building healthier
      futures through collaborative programmes and outreach initiatives.
    </p>

  </div>

</section>

<!-- ========================================= -->
<!-- SCHOOL OUTREACH HIGHLIGHTS -->
<!-- ========================================= -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center mb-20">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">
        SCHOOL OUTREACH
      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">
        School Outreach Highlights
      </h2>

      <p class="mt-8 max-w-4xl mx-auto text-lg leading-9 text-gray-700">
        Through our Healthy Minds, Brighter Futures programme, HealthPsyche and CareBridge Initiatives (HPCBI) has
        continued to support public secondary schools across Lagos State with
        mental wellbeing education, life skills development and digital
        empowerment initiatives.
      </p>

    </div>

    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-3">

      <!-- School 1 -->

      <div class="bg-white rounded-3xl shadow-lg overflow-hidden transition duration-300 hover:-translate-y-2 hover:shadow-2xl">

        <img
          src="/images/gallery/school-1/1.jpg"
          alt="School Outreach Highlights I"
          class="h-72 w-full object-cover"
        />

        <div class="p-8">

          <h3 class="text-2xl font-bold">
            School Outreach Highlights I
          </h3>

          <p class="mt-4 text-gray-600 leading-8">
            Highlights from one of our secondary school mental wellbeing
            programmes delivered as part of our commitment to healthier schools
            and brighter futures.
          </p>

          <a
            href="/school-outreach-1"
            class="inline-block mt-8 text-green-700 font-semibold hover:text-green-900"
          >
            View Photos →
          </a>

