---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us | HealthPsyche and CareBridge Initiatives">

<!-- HERO -->

<section
  class="relative h-[65vh] bg-cover bg-center"
  style="background-image:url('/images/hero/contact.jpg');"
>

  <div class="absolute inset-0 bg-black/65"></div>

  <div class="relative z-10 flex h-full items-center justify-center px-8">

    <div class="max-w-5xl text-center text-white">

      <p class="uppercase tracking-[0.35em] text-green-300 font-semibold">

        CONTACT US

      </p>

      <h1 class="mt-6 text-5xl md:text-7xl font-extrabold">

        We'd Love to

        <span class="text-green-300">

          Hear From You

        </span>

      </h1>

      <p class="mt-10 text-xl leading-10">

        Whether you want to partner with us, request a training,
        support our mission or simply learn more about our work,
        our team is always ready to connect with you.

      </p>

    </div>

  </div>

</section>

<!-- CONTACT INTRODUCTION -->

<section class="py-24 bg-white">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2 class="text-5xl font-bold text-slate-900">

      Let's Build Healthier Communities Together

    </h2>

    <p class="mt-10 text-lg leading-9 text-gray-700">

      HealthPsyche and CareBridge Initiatives (HPCBI) welcomes
      enquiries from schools, government agencies, NGOs,
      development partners, corporate organisations, volunteers,
      researchers and individuals who share our passion for
      promoting mental wellbeing, public health and community
      development.

    </p>

  </div>

</section>

<!-- CONTACT INFORMATION -->

<section class="py-24 bg-slate-50">

<div class="max-w-7xl mx-auto px-8">

<div class="text-center">

<p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

GET IN TOUCH

</p>

<h2 class="mt-6 text-5xl font-bold text-slate-900">

Contact Information

</h2>

<p class="mt-8 text-lg leading-9 text-gray-700 max-w-3xl mx-auto">

We'd be delighted to hear from you. Reach out using any of
the channels below.

</p>

</div>

<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20">

      <!-- EMAIL -->

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          📧

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Email

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          For enquiries, partnerships, sponsorships and
          programme information.

        </p>

        <a
          href="mailto:info@hpcbi.org"
          class="mt-8 inline-block text-green-700 font-bold hover:underline"
        >

          info@hpcbi.org

        </a>

      </div>

      <!-- PHONE -->

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          📱

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Phone / WhatsApp

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Call or send us a WhatsApp message for quick
          enquiries and collaboration opportunities.

        </p>

        <a
          href="https://wa.me/2348034295184"
          target="_blank"
          class="mt-8 inline-block text-green-700 font-bold hover:underline"
        >

          +2348034295184

        </a>

      </div>

      <!-- WEBSITE -->

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🌍

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Website

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Learn more about our programmes, impact stories,
          gallery and opportunities to support our mission.

        </p>

        <a
          href="https://hpcbi.org"
          target="_blank"
          class="mt-8 inline-block text-green-700 font-bold hover:underline"
        >

          www.hpcbi.org

        </a>

      </div>

      <!-- PARTNERSHIPS -->

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🤝

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Partnerships

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          We welcome collaborations with government,
          NGOs, schools, foundations and corporate
          organisations.

        </p>

        <a
          href="mailto:info@hpcbi.org?subject=Partnership Enquiry"
          class="mt-8 inline-block text-green-700 font-bold hover:underline"
        >

          Partner With Us

        </a>

      </div>

    </div>

  </div>

</section>

<!-- CONTACT FORM -->

<section class="py-24 bg-white">

<div class="max-w-5xl mx-auto px-8">

<div class="text-center">

<p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

SEND A MESSAGE

</p>

<h2 class="mt-6 text-5xl font-bold text-slate-900">

We'd Love to Hear From You

</h2>

<p class="mt-8 text-lg leading-9 text-gray-700">

Complete the form below and we'll respond as soon as possible.

</p>

</div>

<div class="mt-16 bg-slate-50 rounded-3xl shadow-xl p-10">

      <form
        action="#"
        method="POST"
        class="space-y-8"
      >

        <!-- Name & Email -->

        <div class="grid md:grid-cols-2 gap-8">

          <div>

            <label
              for="name"
              class="block font-semibold text-slate-700 mb-3"
            >

              Full Name

            </label>

            <input
              type="text"
              id="name"
              name="name"
              placeholder="Enter your full name"
              class="w-full rounded-xl border border-gray-300 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-green-500"
            />

          </div>

          <div>

            <label
              for="email"
              class="block font-semibold text-slate-700 mb-3"
            >

              Email Address

            </label>

            <input
              type="email"
              id="email"
              name="email"
              placeholder="Enter your email address"
              class="w-full rounded-xl border border-gray-300 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-green-500"
            />

          </div>

        </div>

        <!-- Organisation & Phone -->

<div class="grid md:grid-cols-2 gap-8">

  <!-- Organisation -->

  <div>

    <label
      for="organisation"
      class="block font-semibold text-slate-700 mb-3"
    >
      Organisation
    </label>

    <input
      type="text"
      id="organisation"
      name="organisation"
      placeholder="School, NGO, Ministry, Company..."
      class="w-full rounded-xl border border-gray-300 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-green-500"
    />

  </div>

  <!-- Phone -->

  <div>

  <label
    for="phone"
    class="block font-semibold text-slate-700 mb-3"
  >
    Phone Number
    <span class="text-gray-500 text-sm">(Optional)</span>
  </label>

  <input
    id="phone"
    name="phone"
    type="tel"
    class="w-full rounded-xl border border-gray-300 px-5 py-4"
    placeholder="Enter phone number"
  />

 </div>

</div>


        <!-- Subject -->

        <div>

          <label
            for="subject"
            class="block font-semibold text-slate-700 mb-3"
          >

            Subject

          </label>

          <input
            type="text"
            id="subject"
            name="subject"
            placeholder="How can we help you?"
            class="w-full rounded-xl border border-gray-300 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-green-500"
          />

        </div>

        <!-- Message -->

        <div>

          <label
            for="message"
            class="block font-semibold text-slate-700 mb-3"
          >

            Your Message

          </label>

          <textarea
            id="message"
            name="message"
            rows="8"
            placeholder="Write your message here..."
            class="w-full rounded-xl border border-gray-300 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-green-500"
          ></textarea>

        </div>

        <!-- Submit Button -->

        <div class="text-center">

          <button
            type="submit"
            class="bg-green-600 hover:bg-green-700 text-white font-bold px-12 py-5 rounded-xl transition duration-300 shadow-lg"
          >

            Send Message

          </button>

        </div>

      </form>

    </div>

  </div>

</section>

<!-- WHY CONTACT HPCBI -->

<section class="py-24 bg-slate-50">

<div class="max-w-7xl mx-auto px-8">

<div class="text-center">

<p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

WHY WORK WITH US

</p>

<h2 class="mt-6 text-5xl font-bold text-slate-900">

Partner With HealthPsyche and CareBridge Initiatives

</h2>

<p class="mt-8 text-lg leading-9 text-gray-700 max-w-4xl mx-auto">

We collaborate with organisations committed to improving
mental wellbeing, strengthening institutions and building
healthier communities across Nigeria.

</p>

</div>

<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20">

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🤝

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Government Partnerships

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          We support ministries, government agencies and
          public institutions through capacity building,
          workplace wellbeing and organisational development.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🏫

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          School Programmes

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          We partner with schools to promote mental
          wellbeing, inclusive education, AI literacy and
          future-ready life skills for students.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          ❤️

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Community Impact

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          Together with communities and development
          partners, we promote healthier lives through
          mental health awareness and public health
          interventions.

        </p>

      </div>

      <div class="bg-white rounded-3xl shadow-xl p-10 text-center">

        <div class="text-5xl">

          🌍

        </div>

        <h3 class="mt-6 text-2xl font-bold text-slate-900">

          Sustainable Partnerships

        </h3>

        <p class="mt-5 text-gray-600 leading-8">

          We welcome collaboration with NGOs, foundations,
          corporate organisations, donors and international
          partners to expand our impact.

        </p>

      </div>

    </div>

  </div>

</section>

<!-- CALL TO ACTION -->

<section class="py-24 bg-gradient-to-r from-green-700 to-blue-700">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2 class="text-5xl font-bold text-white">

      Let's Build Healthier Minds Together

    </h2>

    <p class="mt-8 text-xl text-white leading-9">

      Whether you are a government agency, school,
      development partner, donor, NGO or corporate
      organisation, HealthPsyche and CareBridge
      Initiatives is ready to work with you to create
      healthier minds, stronger institutions and brighter
      futures.

    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-6">

      <a
        href="mailto:info@hpcbi.org"
        class="bg-white text-green-700 font-bold px-10 py-4 rounded-xl hover:bg-gray-100 transition"
      >

        Email Us

      </a>

      <a
        href="https://wa.me/2348034295184"
        target="_blank"
        class="bg-green-900 text-white font-bold px-10 py-4 rounded-xl hover:bg-green-800 transition"
      >

        WhatsApp Us

      </a>

    </div>

  </div>

</section>

<script type="module">
  import intlTelInput from "https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/+esm";

  const input = document.querySelector("#phone");

  intlTelInput(input, {
    initialCountry: "ng",
    preferredCountries: [
      "ng",
      "us",
      "gb",
      "ca",
      "au",
      "gh",
      "za"
    ],
    separateDialCode: true,
    nationalMode: false,
    autoPlaceholder: "aggressive",
    utilsScript:
      "https://cdn.jsdelivr.net/npm/intl-tel-input@25.3.0/build/js/utils.js",
  });
</script>

</Layout>

