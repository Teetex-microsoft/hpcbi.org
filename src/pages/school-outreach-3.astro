---
import Layout from "../layouts/Layout.astro";
---

<Layout title="School Outreach Highlights III | HealthPsyche and CareBridge Initiatives">

<!-- HERO -->

<section
  class="relative h-[55vh] bg-cover bg-center"
  style="background-image:url('/images/gallery/school-3/1.jpg');"
>

  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 flex h-full items-center justify-center px-8">

    <div class="max-w-4xl text-center text-white">

      <p class="uppercase tracking-[0.35em] text-green-300 font-semibold">

        SCHOOL OUTREACH

      </p>

      <h1 class="mt-6 text-5xl md:text-6xl font-extrabold">

        School Outreach Highlights III

      </h1>

      <p class="mt-8 text-xl leading-9">

        Promoting mental wellbeing, life skills, resilience and healthier
        futures through school-based engagement programmes.

      </p>

    </div>

  </div>

</section>

<!-- INTRODUCTION -->

<section class="py-20 bg-white">

  <div class="max-w-5xl mx-auto px-8 text-center">

    <h2 class="text-4xl font-bold text-slate-900">

      Building Healthier Schools

    </h2>

    <p class="mt-8 text-lg leading-9 text-gray-700">

      This outreach forms part of HealthPsyche and CareBridge Initiatives'
      Healthy Minds, Brighter Futures programme, equipping students with
      practical knowledge on emotional wellbeing, resilience, healthy
      relationships and positive life choices.

    </p>

  </div>

</section>

<!-- IMPACT STATS -->

<section class="py-20 bg-green-700 text-white">

  <div class="max-w-7xl mx-auto px-8">

    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4 text-center">

      <div>

        <h3 class="text-5xl font-extrabold">

          Hundreds

        </h3>

        <p class="mt-4 text-lg">

          Students Reached

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Interactive

        </h3>

        <p class="mt-4 text-lg">

          Mental Wellbeing Sessions

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Lagos

        </h3>

        <p class="mt-4 text-lg">

          Public Secondary Schools

        </p>

      </div>

      <div>

        <h3 class="text-5xl font-extrabold">

          Future Ready

        </h3>

        <p class="mt-4 text-lg">

          Life Skills & Digital Awareness

        </p>

      </div>

    </div>

  </div>

</section>

<!-- PHOTO GALLERY -->

<section class="py-24 bg-slate-50">

  <div class="max-w-7xl mx-auto px-8">

    <div class="text-center mb-16">

      <p class="uppercase tracking-[0.35em] text-green-600 font-semibold">

        PHOTO GALLERY

      </p>

      <h2 class="mt-6 text-5xl font-bold text-slate-900">

        School Outreach Highlights III

      </h2>

      <p class="mt-6 text-lg text-gray-600">

        Six moments captured during this outreach programme.

      </p>

    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      <a href="/images/gallery/school-3/1.jpg">

        <img
          src="/images/gallery/school-3/1.jpg"
          alt="School Outreach Photo 1"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/school-3/2.jpg">

        <img
          src="/images/gallery/school-3/2.jpg"
          alt="School Outreach Photo 2"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/school-3/3.jpg">

        <img
          src="/images/gallery/school-3/3.jpg"
          alt="School Outreach Photo 3"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/school-3/4.jpg">

        <img
          src="/images/gallery/school-3/4.jpg"
          alt="School Outreach Photo 4"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/school-3/5.jpg">

        <img
          src="/images/gallery/school-3/5.jpg"
          alt="School Outreach Photo 5"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

      <a href="/images/gallery/school-3/6.jpg">

        <img
          src="/images/gallery/school-3/6.jpg"
          alt="School Outreach Photo 6"
          class="rounded-3xl shadow-xl w-full h-80 object-cover hover:scale-105 transition duration-300"
        />

      </a>

    </div>

  </div>

</section>

<!-- NAVIGATION -->

<section class="py-20 bg-white">

  <div class="max-w-6xl mx-auto px-8">

    <div class="flex flex-wrap justify-between gap-6">

      <a
        href="/gallery"
        class="bg-slate-800 text-white px-8 py-4 rounded-xl font-bold hover:bg-slate-900 transition"
      >

        ← Back to Gallery

      </a>

      <a
        href="/school-outreach-4"
        class="bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition"
      >

        Next Gallery →

      </a>

    </div>

  </div>

</section>

</Layout>