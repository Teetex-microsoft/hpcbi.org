---
const programmes = [
  {
    title: "Healthy Minds Brighter Futures",
    href: "/programmes",
  },
  {
    title: "School Impact",
    href: "/school-impact",
  },
  {
    title: "Government Capacity Building",
    href: "/government-capacity-building",
  },
  {
    title: "Community Mental Health",
    href: "/community-mental-health",
  },
];
---

<section
  class="relative min-h-screen bg-cover bg-center"
  style="background-image:url('/images/hero/hero-school.jpg');"
>

  <!-- Overlay -->

  <div class="absolute inset-0 bg-black/60"></div>

  <!-- ========================= -->
  <!-- HEADER -->
  <!-- ========================= -->

  <header class="absolute top-0 left-0 w-full z-50">

    <nav class="max-w-7xl mx-auto flex items-start justify-between px-8 pt-8">

      <!-- Logo -->

      <a
        href="/"
        class="flex items-start gap-5 flex-shrink-0"
      >

        <img
          src="/images/logos/hpcbi-logo-circle.png"
          alt="HPCBI Logo"
          class="w-16 h-16 rounded-full bg-white p-1"
        />

        <div>

          <h2
            class="text-white font-bold text-xl leading-tight"
          >

            HealthPsyche and

            <br />

            CareBridge Initiatives

          </h2>

          <p class="text-green-300 font-bold mt-1">

            (HPCBI)

          </p>

        </div>

      </a>

      <!-- ========================= -->
      <!-- Desktop Menu -->
      <!-- ========================= -->

      <div class="hidden lg:flex items-center gap-12">

        <ul
          class="flex items-center gap-6 text-white font-semibold"
        >

          
          <li>

            <a
              href="/about"
              class="hover:text-green-300 transition"
            >

              About

            </a>

          </li>

          <li>

            <a
              href="/inclusive-education"
              class="hover:text-green-300 transition"
            >

              Inclusive Education

            </a>

          </li>

          <!-- ========================= -->
          <!-- PROGRAMMES DROPDOWN -->
          <!-- ========================= -->

          <li class="relative">

            <button
              id="programmes-button"
              class="flex items-center gap-2 hover:text-green-300 transition"
            >

              Programmes

              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >

                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />

              </svg>

            </button>

            <div
              id="programmes-menu"
              class="absolute left-0 top-full mt-4 w-80 rounded-2xl bg-white shadow-2xl overflow-hidden hidden"
            >

                          {programmes.map((programme) => (

                <a
                  href={programme.href}
                  class="block px-6 py-4 text-slate-700 hover:bg-green-50 hover:text-green-700 transition"
                >

                  {programme.title}

                </a>

              ))}

            </div>

          </li>

          <li>

            <a
              href="/gallery"
              class="hover:text-green-300 transition"
            >

              Gallery

            </a>

          </li>

          <li>

            <a
              href="/news"
              class="hover:text-green-300 transition"
            >

              News & Stories

            </a>

          </li>

          <li>

            <a
              href="/contact"
              class="hover:text-green-300 transition"
            >

              Contact

            </a>

          </li>

        </ul>

        <a
          href="/support-our-mission"
          class="bg-green-500 hover:bg-green-400 text-black font-bold px-7 py-3 rounded-xl transition"
        >

          Support Our Mission

        </a>

      </div>

      <!-- ========================= -->
      <!-- Mobile Menu Button -->
      <!-- ========================= -->

      <button
        id="mobile-menu-button"
        class="lg:hidden text-white text-4xl"
        aria-label="Open Menu"
      >

        ☰

      </button>

    </nav>

    <!-- ========================= -->
    <!-- Mobile Menu -->
    <!-- ========================= -->

    <div
      id="mobile-menu"
      class="hidden lg:hidden bg-black/95 backdrop-blur-md"
    >

      <div class="flex flex-col px-8 py-8 space-y-5">

        
        <a href="/about" class="text-white hover:text-green-300">

          About

        </a>

        <a href="/inclusive-education" class="text-white hover:text-green-300">

          Inclusive Education

        </a>

        <a href="/programmes" class="text-white hover:text-green-300">

          Healthy Minds Brighter Futures

        </a>

        <a href="/school-impact" class="text-white hover:text-green-300">

          School Impact

        </a>

        <a href="/government-capacity-building" class="text-white hover:text-green-300">

          Government Capacity Building

        </a>

        <a href="/community-mental-health" class="text-white hover:text-green-300">

          Community Mental Health

        </a>

        <a href="/gallery" class="text-white hover:text-green-300">

          Gallery

        </a>

        <a href="/news" class="text-white hover:text-green-300">

          News & Stories

        </a>

        <a href="/contact" class="text-white hover:text-green-300">

          Contact

        </a>

        <a
          href="/support-our-mission"
          class="bg-green-500 hover:bg-green-400 text-black font-bold rounded-xl py-3 text-center transition"
        >

          Support Our Mission

        </a>

      </div>

    </div>

  </header>

    <!-- ========================= -->
  <!-- HERO CONTENT -->
  <!-- ========================= -->

  <div
    class="relative z-10 max-w-7xl mx-auto px-8 min-h-screen flex items-center"
  >

    <div class="max-w-4xl pt-36">

      <h1
        class="text-center lg:text-left text-white font-extrabold leading-tight text-4xl md:text-6xl"
      >

        Healthy Minds.

        <br />

        <span class="text-green-300">

          Brighter Futures.

        </span>

      </h1>

      <p
        class="mt-10 max-w-4xl text-white text-xl leading-10 text-justify"
      >

        Building healthier minds, stronger communities and
        preparing a future-ready generation through mental
        wellbeing, public health, Artificial Intelligence (AI)
        and digital innovation.

      </p>

      <p
        class="mt-8 max-w-4xl text-gray-200 text-lg leading-9 text-justify"
      >

        HealthPsyche and CareBridge Initiatives (HPCBI) is a
        Nigerian nonprofit organisation committed to promoting
        mental wellbeing, improving public health, empowering
        young people with future-ready digital skills,
        supporting inclusive education, strengthening
        institutions and building healthier communities through
        sustainable partnerships and innovative programmes.

      </p>

      <div
        class="mt-12 flex flex-wrap gap-6"
      >

        <a
          href="/school-impact"
          class="bg-green-500 hover:bg-green-400 text-black font-bold px-8 py-4 rounded-xl transition"
        >

          Explore Our Impact

        </a>

        <a
          href="/support-our-mission"
          class="border-2 border-white hover:bg-white hover:text-black text-white font-semibold px-8 py-4 rounded-xl transition"
        >

          Support Our Mission

        </a>

      </div>

    </div>

  </div>

  <!-- ========================= -->
  <!-- Scroll Indicator -->
  <!-- ========================= -->

  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-20"
  >

    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-8 h-8 text-white"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >

      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19 9l-7 7-7-7"
      />

    </svg>

  </div>

</section>

<script>

document.addEventListener("DOMContentLoaded", () => {

  /* ===========================
     MOBILE MENU
  =========================== */

  const mobileButton =
    document.getElementById("mobile-menu-button");

  const mobileMenu =
    document.getElementById("mobile-menu");

  if (mobileButton && mobileMenu) {

    mobileButton.addEventListener("click", () => {

      mobileMenu.classList.toggle("hidden");

    });

  }

  /* ===========================
     PROGRAMMES DROPDOWN
  =========================== */

  const programmesButton =
    document.getElementById("programmes-button");

  const programmesMenu =
    document.getElementById("programmes-menu");

  if (programmesButton && programmesMenu) {

    let timeout;

    function openMenu() {

      clearTimeout(timeout);

      programmesMenu.classList.remove("hidden");

    }

    function closeMenu() {

      timeout = setTimeout(() => {

        programmesMenu.classList.add("hidden");

      }, 200);

    }

    programmesButton.addEventListener("mouseenter", openMenu);

    programmesMenu.addEventListener("mouseenter", openMenu);

    programmesButton.addEventListener("mouseleave", closeMenu);

    programmesMenu.addEventListener("mouseleave", closeMenu);

    document.addEventListener("click", (event) => {

      if (
        !programmesButton.contains(event.target) &&
        !programmesMenu.contains(event.target)
      ) {

        programmesMenu.classList.add("hidden");

      }

    });

  }

});

</script>